/// Help - Story

"help.story.title" = "**Historia**";

"help.story.1" = "W roku 2300 ludzkość osiągnęła technologię niezbędną do terraformowania planet Układu Słonecznego. Misję prowadził zespół genialnych naukowców i inżynierów, którzy poświęcili swoje życie temu ambitnemu celowi.";

"help.story.2" = "Ostatnią planetą do terraformowania był Neptune, który od dawna uważany był za najbardziej obiecującego kandydata do budowy ludzkich kolonii do eksploracji zewnętrznego Układu Słonecznego. Zespół wykorzystał samoreplikujące się nanomaszyny do zmiany powierzchni i atmosfery planety w dziedzinie Astrobiologii.";

"help.story.section1.title" = "Projekt EvE-PALMA";

"help.story.3" = "Projekt tworzenia nanomaszyn został nazwany **EvE-PALMA**, co oznacza **Ev**olutionary **E**xperiments of **P**rogrammable **A**rtificial **L**ife by **M**olecular **A**utomata.";

"help.story.section2.title" = "PENTAN";

"help.story.4" = "Nanomaszyna opracowana w ramach projektu została nazwana **PENTAN**, czyli **P**rogrammable and **E**volvable **N**anomachines for **T**erraforming the **A**strobiology of **N**eptune.";

"help.story.5" = "Zespół wystrzelił liczne PENTANy, osadzając je w drobnych lodach i wysyłając z pierścieni Saturn na błękitne metanowe chmury Neptune.";

"help.story.6" = "Jednak prawie wszystkie rozmieszczone PENTANy zdziczały i stały się niekontrolowalne w ciągu kilkudziesięciu lat, pomimo starannego projektu zespołu. Coś wpłynęło na PENTANy i je zmodyfikowało, co silnie wskazywało na obecność życia na Neptune.";

"help.story.section3.title" = "Twoja misja";

"help.story.7" = "Jesteś naukowcem z dziedziny Astrobiologii w projekcie EvE-PALMA. Twoją misją jest zaprojektowanie nowej generacji PENTANów, które zastąpią stare, zdziczałe, i terraformowanie Neptune!";

"help.story.episodes.title" = "Epizody";

/// Help - Episodes

"help.episodes.title" = "**Epizody**";

"help.episodes.subtitle" = "Przeprojektowanie **PENTAN**";

"help.episodes.1" = "Samotność laboratorium dawała uspokajający szum, a ciche brzęczenie maszyn stanowiło jedyną ścieżkę dźwiękową, jakiej Tony*Theta7* potrzebował. Jako Astrobiolog zawsze fascynowały go tajemnice wszechświata. Teraz stał na czele jednego z najbardziej ambitnych projektów, jakie ludzkość kiedykolwiek podjęła: **EvE-PALMA**.";
"help.episodes.2" = "To był akronim, który śpiewał obietnicą i aspiracją: **Ev**olutionary **E**xperiments of **P**rogrammable **A**rtificial **L**ife by **M**olecular **A**utomata. Jego zadanie? Zbudować nanomaszyny zdolne do terraformowania ostatniego nietkniętego klejnotu Układu Słonecznego, Neptune.";
"help.episodes.3" = "Jego arcydzieło, PENTAN, zostało zaprojektowane dokładnie w tym celu. **P**rogrammable and **E**volvable **N**anomachines for **T**erraforming the **A**strobiology of **N**eptune - dzieło, które w swojej mikroskopijnej strukturze kryło potencjał do przekształcenia całej planety. ";
"help.episodes.4" = "Jednak sukces był nieuchwytny. Pierwsza generacja PENTANów, niegdyś tak obiecująca, wymknęła się spod kontroli. Zostały wypuszczone w metanowe chmury Neptune, podróżując na lodowych cząsteczkach z pierścieni Saturn. Ale zamiast rozpocząć proces terraformowania, stały się niekontrolowalne, dzikie.";
"help.episodes.5" = "Teraz Tony*Theta7* znalazł się w kluczowym momencie. Jego wyzwaniem było zaprojektowanie nowej generacji PENTANów, takich, które nie powtórzą porażek swoich poprzedników. Poprzedni projekt wskazywał na możliwą obecność życia na Neptune, co było zarówno ekscytującym odkryciem, jak i przeszkodą w ich misji.";
"help.episodes.6" = "Tony siedział pochylony nad swoją pracą, z nachmurzonymi brwiami skupiony na zadaniu. Obrazy wirujących metanowych chmur i błękitnych niebios wypełniały jego ekrany. Każda linia kodu, którą pisał, była potencjalnym rozwiązaniem, nową smyczą na dzikie PENTANy.";
"help.episodes.7" = "Jego palce latały po klawiaturze, a rytmiczne klikanie klawiszy stało się częścią dźwięku laboratorium. Na ekranie złożone plany automatów molekularnych ożywały. Każdy projekt był bardziej zaawansowany, bardziej zdolny, bardziej kontrolowany.";
"help.episodes.8" = "Nowe PENTANy musiały być inne. Musiały być zaprojektowane z wiedzą, że Neptune może już posiadać życie, czynnik, który nie został uwzględniony w poprzednim projekcie. Tony*Theta7* musiał zapewnić, że te nanomaszyny będą działać w harmonii z istniejącymi formami życia.";
"help.episodes.9" = "Gdy wprowadzał ostatnie linie kodu, poczuł przypływ oczekiwania. Prostym poleceniem drukarka ożyła, tworząc trójwymiarowy model ulepszonego PENTANa. Jego złożoność była hipnotyzująca - świadectwo ludzkiej innowacji i niezachwianego pragnienia eksploracji niezbadanego.";
"help.episodes.10" = "Dla Tony*Theta7* był to kulminacja niestrudzonych wysiłków, krok bliżej do osiągnięcia wzniosłego celu terraformowania Neptune. Ale prawdziwy test jego dzieła wciąż czekał, w zimnych głębinach atmosfery błękitnej planety, gdzie nowe PENTANy miały albo ujarzmić dzikość swoich poprzedników, albo podzielić ten sam los.";
"help.episodes.11" = "Rozdział terraformowania Neptune wciąż był pisany, a Tony*Theta7* trzymał pióro.";

/// Help - The Game

"help.games.title" = "Gry";

"help.games.1" = "GoCAKs";
"help.games.1-1" = "GoCAKs /goʊ-kɜrks/ to\n***G***ra ***o*** ***C***ellular ***A***utomaton dla ***K***id***s***";
"help.games.1-2" = "Wspomniany tutaj **automat komórkowy** to coś w rodzaju programu komputerowego.";
"help.games.1-3" = "W tej wersji GoCAKs grasz, manipulując figurą zwaną **PENTAN** (automatem komórkowym) w świecie przedstawionym na dwuwymiarowej siatce, podobnej do szachownicy. PENTAN porusza się zgodnie z wcześniej zadanym programem.";

"help.games.2" = "GoCAKs jako podstawowe narzędzie do nauki programowania";
"help.games.2-1" = "Program dla PENTANa tworzony jest poprzez łączenie kilku instrukcji.";
"help.games.2-2" = "Łącząc instrukcje, możesz tworzyć różnorodne ruchy i zjawiska.";
"help.games.2-3" = "Granie w GoCAKs jest samo w sobie programowaniem.";
"help.games.2-4" = "Grając w GoCAKs, możesz naturalnie nauczyć się podstawowych koncepcji programowania, takich jak pętle, rozgałęzienia warunkowe i zmienne.";

"help.games.3" = "**PENTAN** jako zaprogramowana forma życia";
"help.games.3-1" = "W świecie GoCAKs automat komórkowy nazywany jest **PENTAN**.";
"help.games.3-2" = "PENTAN, samoreplikująca się nanomaszyna, zachowuje się czasami jak pojedyncza komórka, a czasami jak organizm wielokomórkowy współpracujący z innymi.";
"help.games.3-3" = "PENTAN posiada następujące atrybuty.";

"help.games.pentan.title.1" = "Energia";
"help.games.pentan.description.1" = "Energia jest źródłem aktywności PENTANa.\n\nW miarę zmniejszania się energii kolor PENTANa staje się bledszy. Gdy energia spadnie do zera, PENTAN znika.";
"help.games.pentan.title.2" = "Stan";
"help.games.pentan.description.2" = "PENTAN posiada stan.\n\nStan to liczba reprezentująca pozycję kodu, który PENTAN aktualnie wykonuje. Gdy PENTAN wykonuje określony kod, stan się zmienia i wskazuje na pozycję następnego kodu do wykonania. PENTAN nie może poznać stanu innych PENTANów.";
"help.games.pentan.title.3" = "Pamięć";
"help.games.pentan.description.3" = "PENTAN może zapamiętać tylko jedną liczbę. Niektóre kody zmieniają swoje działanie w zależności od liczby, którą PENTAN pamięta.";
"help.games.pentan.title.4" = "Kierunek";
"help.games.pentan.description.4" = "PENTAN posiada kierunek. PENTAN może zmieniać swój kierunek. Określony kod wpływa na sąsiedniego PENTANa w kierunku, w którym PENTAN jest zwrócony.";
"help.games.pentan.title.5" = "Kierunek ręki";
"help.games.pentan.description.5" = "PENTAN ma tylko jedną rękę.\n\nRęka ma kierunek, a PENTAN może zmieniać kierunek ręki. PENTAN może użyć ręki, aby przyczepiać się do sąsiedniego PENTANa. Gdy PENTAN, do którego jest przymocowany, się porusza, może się również przesuwać.";
"help.games.pentan.title.6" = "Kolor";
"help.games.pentan.description.6" = "PENTAN posiada kolor. \n\nKolor można zmieniać. PENTAN może widzieć kolor innych PENTANów.";
"help.games.pentan.title.7" = "Genom";
"help.games.pentan.description.7" = "Program PENTANa nazywany jest genomem.\n\nGenom to zbiór kodów połączonych w określonej kolejności.\n\nIm dłuższy genom, tym bardziej złożony program może wyrażać.\n\nJednak istnieją instrukcje wymagające dużo energii do wykonania, takie jak instrukcje replikacji PENTANa, a im dłuższy genom, tym więcej energii potrzeba.\n\nDlatego weź pod uwagę, że im krótszy genom, tym łatwiej PENTANowi się rozmnażać, a im dłuższy genom, tym trudniej mu się rozmnażać.";

"help.games.4" = "Pola";

"help.games.4-1" = "W dwuwymiarowym świecie siatki, w którym działa PENTAN, istnieją miejsca o różnych właściwościach.";

"help.games.fields.title.1" = "Pole energii";
"help.games.fields.description.1" = "To miejsce, z którego tryska energia cieplna, służąca jako energia dla PENTANa. PENTAN może tu uzupełnić swoją energię.";
"help.games.fields.title.2" = "Pole trucizny";
"help.games.fields.description.2" = "To miejsce zawierające wiele substancji toksycznych dla PENTANa. Substancje te będą wyczerpywać energię PENTANa. Jeśli PENTAN zbyt długo pozostanie w tym miejscu, jego energia będzie stopniowo maleć i ostatecznie zniknie.";
"help.games.fields.title.3" = "Pole promieniowania";
"help.games.fields.description.3" = "To miejsce, w którym występuje promieniowanie. Z powodu efektów promieniowania delikatna nanostruktura PENTANa ulega uszkodzeniu, powodując zmiany w stanie i kodzie PENTANa.";
"help.games.fields.title.4" = "Pole promieniowania";
"help.games.fields.description.4" = "To miejsce, do którego PENTAN nie może wejść.";
"help.games.fields.title.5" = "";
"help.games.fields.description.5" = "";

"help.games.timeandbudget" = "Czas i budżet";
"help.games.timeandbudget.description" = "W trybie Szybkiego Biegu istnieją ograniczenia czasu i budżetu, które możesz wykorzystać na każdym etapie.";

"help.games.time.title" = "Czas";
"help.games.time.description" = "W trybie Szybkiego Biegu istnieje limit czasu na każdy etap. W wyznaczonym czasie musisz wyeliminować wszystkich wrogów. Po upływie limitu czasu gra się kończy i musisz zrestartować etap od początku.";

"help.games.budget.title" = "Budżet";
"help.games.budget.description" = "W trybie Szybkiego Biegu istnieje limit budżetu na każdy etap. Umieszczanie, usuwanie lub modyfikowanie PENTANów zużywa budżet. Gdy budżet się wyczerpie, nie możesz dalej operować PENTANami na tym etapie. Resetując, czas wraca do 0, a wykorzystany budżet również resetuje się do 0.";

"help.games.howtoplay" = "Jak grać";
"help.games.speedrun.title" = "Tryb Szybkiego Biegu";
"help.games.speedrun.description" = "To gra, w której rywalizujesz o wyeliminowanie wrogów w jak najkrótszym czasie i przy jak najmniejszych zasobach.\n\nSą etapy od Poziomu 1 do Poziomu 7. W wyznaczonym czasie i budżecie postaraj się efektywnie tworzyć PENTANy, aby wyeliminować wszystkich wrogów.";
"help.games.creative.title" = "Tryb Kreatywny";
"help.games.creative.description" = "To tryb, w którym możesz swobodnie tworzyć PENTANy i przeprowadzać różne eksperymenty.\n\nUwolnij swoją kreatywność i twórz PENTANy, które wywołują ciekawe ruchy i zjawiska.";

/// Help - FAQ

"help.faq.title" = "FAQ";

"faqs.item1.title" = "Użycie w szkołach";
"faqs.item1.description" = "P. Czy GoCAKs może być używany na lekcjach w szkole?\n\nO. Tak, GoCAKs może być używany na lekcjach szkolnych. Możesz swobodnie tworzyć i rozpowszechniać materiały, takie jak zrzuty ekranu. Dopuszczalne jest również używanie go na płatnych zajęciach z programowania.";

"faqs.item2.title" = "Tworzenie filmów";
"faqs.item2.description" = "P. Czy mogę tworzyć i udostępniać filmy z gry GoCAKs?\n\nO. Tak, możesz tworzyć filmy i udostępniać je na platformach takich jak YouTube. Możesz również zarabiać na tych filmach.";

/// Codes

"help.codes.title" = "Kody";
"help.codes.code.title" = "Kod";
"help.codes.code.description" = "Jeden kod składa się z polecenia i parametru.\n\nParametr jest reprezentowany przez liczbę, a niektóre polecenia używają parametru, podczas gdy inne nie.\n\nInstrukcje w GoCAKs zostały starannie dobrane i bardzo dobrze opracowane.\n\nChociaż każda instrukcja jest prosta i łatwa do zrozumienia, możliwości ruchów i zjawisk, które można stworzyć z ich kombinacji, są nieskończone.\n\nWidowisko starannie zaprojektowanych PENTANów rywalizujących o przetrwanie prawdopodobnie stworzyłoby zjawisko podobne do ekosystemu.";

