"codes.nop.text" = "NOP";
"codes.nop.description" = "אין פעולה. זוהי פקודה שלא עושה כלום.\n\nאין צריכת אנרגיה.\n\nבניגוד לפקודת SLEEP, ה-PENTAN נשאר פעיל. לכן, גם אם הותקף על ידי PENTANים אחרים, הוא לא יפסיד ליריבים עם פחות אנרגיה.";
"codes.move.text" = "MOVE";
"codes.move.description" = "זוהי פקודה להזיז את PENTAN בכיוון שאליו הוא פונה בהתאם למספר ולסימן של הפרמטרים.\n\nכשהפרמטר הוא מספר חיובי, הוא נע קדימה. כשהוא שלילי, הוא נע אחורה. בכל פעימת זמן, הוא נע משבצת אחת, וממשיך לנוע מספר פעמים כערך הפרמטר.\n\nהוא קודם זוכר את מספר הפרמטר ואז מקטין את המספר הזכור ב-1 על כל משבצת שהוא נע.\n\nהתנועה נעצרת כשהמספר הזכור מגיע ל-0, או אם יש PENTAN אחר בכיוון התנועה, או אם יש משבצת בלתי נגישה.";
"codes.turn.text" = "TURN";
"codes.turn.description" = "זוהי פקודה לשנות את כיוון PENTAN בהתאם למספר ולסימן של הפרמטרים.\n\nכשהפרמטר הוא מספר חיובי, הוא מסתובב בכיוון השעון. כשהוא שלילי, הוא מסתובב נגד כיוון השעון. לדוגמה, כשהפרמטר הוא +4, הוא מבצע סיבוב שלם, כך שכיוון PENTAN אינו משתנה. כמו כן, כשמספר הפרמטר הוא 0, כיוון PENTAN מתאפס לצפון.";
"codes.jump.text" = "JUMP";
"codes.jump.description" = "זוהי פקודה לשנות את מצב PENTAN (המייצג את מיקום הביצוע של התוכנית) על סמך המספר והסימן של הפרמטרים.\n\nכשהפרמטר הוא מספר חיובי, המצב עובר לערך גדול יותר, וכשהוא שלילי, המצב עובר לערך קטן יותר. לדוגמה, אם מספר הפרמטר הוא -1, הוא חוזר למצב הקודם. אם מספר הפרמטר הוא 0, המצב פשוט מתקדם לקוד הבא. אם מספר הפרמטר הוא +1, הוא מדלג על הקוד הבא ומקדם את המצב קדימה.";
"codes.sleep.text" = "SLEEP";
"codes.sleep.description" = "זוהי פקודה לגרום ל-PENTAN לישון.\n\nהוא ממשיך לישון למשך אותו פרק זמן כמו המספר בפרמטר.\n\nבזמן השינה, האנרגיה של PENTAN עולה בהדרגה.\n\nעם זאת, אם הוא מותקף בזמן השינה, כל האנרגיה שלו תיגנב והוא ימות.";
"codes.give.text" = "GIVE";
"codes.give.description" = "הוא מחלק ונותן חצי מהאנרגיה שלו ל-PENTAN השכן בכיוון שאליו הוא פונה.\n\nאם אין PENTAN אחר מולו, האנרגיה שלו יורדת ב-1.";
"codes.eat.text" = "EAT";
"codes.eat.description" = "הוא תוקף את ה-PENTAN השכן בכיוון שאליו הוא פונה.\n\nזה שיש לו יותר אנרגיה נשאר וזה שיש לו פחות אנרגיה נעלם. באותו זמן, האנרגיה של ה-PENTAN שנשאר יורדת בכמות שווה לאנרגיה של ה-PENTAN שנעלם. עם זאת, אם ה-PENTAN השכן במצב שינה, גם אם ליריב יש יותר אנרגיה, אתה יכול לנצח מבלי להפחית את האנרגיה שלך.";
"codes.color.text" = "COLOR";
"codes.color.description" = "זוהי פקודה לשנות את הצבע של PENTAN.\n\nהוא משתנה לצבע המתאים למספר בפרמטר.";
"codes.look.text" = "LOOK";
"codes.look.description" = "זוהי פקודה לקרוא ולזכור את הצבע של ה-PENTAN שלידך, בכיוון שאליו PENTAN מצביע.";
"codes.field.text" = "FIELD";
"codes.field.description" = "זוהי פקודה לחקור את סוג המשבצת שבה PENTAN נמצא, ולשנן את המספר המייצג את סוג המשבצת.";
"codes.add.text" = "ADD";
"codes.add.description" = "זוהי פקודה להוסיף את מספר הפרמטר למספר ש-PENTAN זוכר.\n\nאם מספר הפרמטר שלילי, המספר ש-PENTAN זוכר יקטן בכמות של מספר הפרמטר.";
"codes.minus.text" = "MINUS";
"codes.minus.description" = "זוהי פקודה להחסיר את מספר הפרמטר מהמספר ש-PENTAN זוכר.";
"codes.memory.text" = "MEMORY";
"codes.memory.description" = "זוהי פקודה לזכור את המספר בפרמטר.";
"codes.read.text" = "READ";
"codes.read.description" = "זוהי פקודה ש-PENTAN קורא וזוכר את הפרמטר של הקוד הנמצא במיקום שהוא סכום מצבו הנוכחי והפרמטר, מה-PENTAN השכן בכיוון שאליו הוא פונה.\n\nלדוגמה, אם המצב הנוכחי הוא 5 והפרמטר הוא +1, הוא יקרא ויזכור את הפרמטר של הקוד במיקום 6 מה-PENTAN השכן.";
"codes.write.text" = "WRITE";
"codes.write.description" = "זוהי פקודה ש-PENTAN כותב את המספר שהוא זוכר לפרמטר של הקוד הנמצא במיקום שהוא סכום מצבו הנוכחי והפרמטר.\n\nלדוגמה, אם הפרמטר הוא +1, הוא יכתוב את המספר ש-PENTAN זוכר לפרמטר של הקוד הבא.";
"codes.split.text" = "SPLIT";
"codes.split.description" = "זוהי פקודה ש-PENTAN מייצר PENTAN חדש על ידי חילוץ קטע קוד מסוים מהגנום שלו.\n\nקטע הקוד לחילוץ מתחיל מהקוד הנמצא במיקום שהוא סכום מצבו הנוכחי והפרמטר ומשתרע בשני הכיוונים עד שהוא מוגבל על ידי קוד 'NOP' (קטע זה מכונה קטע NOP).\n\nביצוע פקודה זו צורך כמות אנרגיה השווה לאורך הגנום. כמו כן, לאחר ביצוע הפקודה, חצי מהאנרגיה הנותרת ניתנת ל-PENTAN שנוצר.\n\nהמצב ההתחלתי של ה-PENTAN שנוצר יהיה מספר הקוד במיקום ההתחלתי של קטע ה-NOP.";
"codes.copy.text" = "COPY";
"codes.copy.description" = "זוהי פקודה ש-PENTAN משכפל את עצמו למיקום השכן בכיוון שאליו הוא פונה.\n\nהמשבצת שמול PENTAN צריכה להיות נגישה ולא יכול להיות בה PENTAN אחר.\n\nביצוע פקודה זו דורש כמות אנרגיה השווה לאורך הגנום שלו. כמו כן, לאחר ביצוע הפקודה, חצי מהאנרגיה הנותרת ניתנת ל-PENTAN החדש המשוכפל.\n\nהמצב ההתחלתי של ה-PENTAN המשוכפל מוגדר למספר שהוא סכום מצבו הנוכחי והפרמטר.";
"codes.end.text" = "END";
"codes.end.description" = "זוהי פקודה להשמדה עצמית של PENTAN. עם זאת, הפקודה מתבצעת רק כשהמספר ש-PENTAN זוכר זהה למספר הפרמטר.";
"codes.cross.text" = "CROSS";
"codes.cross.description" = "זוהי פקודה ש-PENTAN מחליף קטע קוד מסוים עם PENTAN אחר הנמצא מולו.\n\nקטע הקוד להחלפה מתחיל מהקוד הנמצא במיקום שהוא סכום מצבו הנוכחי והפרמטר, ומשתרע בשני הכיוונים עד שהוא מוגבל על ידי קוד 'wait' (קטע זה מכונה קטע NOP).\n\nאם לשני הצדדים אין קטעי NOP תואמים, החלפת הקוד לא תתבצע.\n\nביצוע פקודה זו דורש כמות אנרגיה השווה לאורך הגנום שלו.";
"codes.code.text" = "CODE";
"codes.code.description" = "זוהי פקודה להוספת קוד לסוף הגנום של PENTAN. ההוראה של הקוד המוסף תתאים למספר הפרמטר. הפרמטר של הקוד המוסף יהיה המספר בזיכרון.";
"codes.equal.text" = "EQUAL";
"codes.equal.description" = "זוהי פקודה שמאחסנת 1 כשערך הפרמטר תואם את הערך המאוחסן על ידי PENTAN, ומאחסנת 0 כשהוא אינו תואם.";
"codes.stick.text" = "STICK";
"codes.stick.description" = "זוהי פקודה לשנות את כיוון היד של PENTAN או לכווץ אותה, בהתאם למספר ולסימן של הפרמטרים.\n\nכשהפרמטר הוא מספר חיובי, היד מסתובבת בכיוון השעון. כשהוא שלילי, היא מסתובבת נגד כיוון השעון. לדוגמה, כשהפרמטר הוא +4, היד מבצעת סיבוב שלם, כך שכיוון היד של PENTAN אינו משתנה. אם מספר הפרמטר הוא 0, היד של PENTAN נכווצת.";
