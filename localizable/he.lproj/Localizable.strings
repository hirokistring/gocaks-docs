/// Help - Story

"help.story.title" = "**הסיפור**";

"help.story.1" = "בשנת 2300, האנושות השיגה את הטכנולוגיה הנדרשת לטרפורמציה של כוכבי מערכת השמש. את המשימה הובילה קבוצת מדענים ומהנדסים מבריקים שהקדישו את חייהם למטרה שאפתנית זו.";

"help.story.2" = "הכוכב האחרון לטרפורמציה היה Neptune, שנחשב מזמן למועמד המבטיח ביותר לבניית מושבות אנושיות לחקירת מערכת השמש החיצונית. הצוות השתמש בננו-מכונות בעלות שכפול עצמי לשינוי פני השטח והאטמוספירה של הכוכב בתחום האסטרוביולוגיה.";

"help.story.section1.title" = "פרויקט EvE-PALMA";

"help.story.3" = "הפרויקט לעיצוב הננו-מכונות נקרא **EvE-PALMA**, שמשמעותו **Ev**olutionary **E**xperiments of **P**rogrammable **A**rtificial **L**ife by **M**olecular **A**utomata.";

"help.story.section2.title" = "PENTAN";

"help.story.4" = "הננו-מכונה שפותחה מהפרויקט נקראה **PENTAN**, או **P**rogrammable and **E**volvable **N**anomachines for **T**erraforming the **A**strobiology of **N**eptune.";

"help.story.5" = "הצוות שיגר PENTANים רבים על ידי שיבוצם בקרחונים זעירים ושליחתם מהטבעות של Saturn לעננות המתאן הכחולות של Neptune.";

"help.story.6" = "עם זאת, כמעט כל ה-PENTANים שהוצבו השתוללו ונעשו בלתי נשלטים תוך עשורים, למרות התכנון הקפדני של הצוות. משהו השפיע על ה-PENTANים ושינה אותם, מה שהצביע בחוזקה על נוכחות חיים ב-Neptune.";

"help.story.section3.title" = "המשימה שלך";

"help.story.7" = "אתה מדען אסטרוביולוגיה בפרויקט EvE-PALMA. המשימה שלך היא לעצב דור חדש של PENTANים שיחליפו את הישנים שהשתוללו ולבצע טרפורמציה של Neptune!";

"help.story.episodes.title" = "הפרקים";

/// Help - Episodes

"help.episodes.title" = "**הפרקים**";

"help.episodes.subtitle" = "עיצוב מחדש של **PENTAN**";

"help.episodes.1" = "הבדידות של המעבדה שלו סיפקה זמזום מרגיע, והרחש החלש של המכונות היה פסקול היחיד ש-Tony*Theta7* היה צריך. כאסטרוביולוג, הוא תמיד היה מוקסם מתעלומות היקום. כעת, הוא עמד בחזית אחד הפרויקטים השאפתניים ביותר שהאנושות ביצעה: **EvE-PALMA**.";
"help.episodes.2" = "זה היה ראשי תיבות שהדהדו הבטחה ושאיפה: **Ev**olutionary **E**xperiments of **P**rogrammable **A**rtificial **L**ife by **M**olecular **A**utomata. המשימה שלו? לבנות ננו-מכונות המסוגלות לבצע טרפורמציה של הפנינה האחרונה שלא נוגעה במערכת השמש, Neptune.";
"help.episodes.3" = "יצירת המופת שלו, PENTAN, עוצבה בדיוק למטרה זו. **P**rogrammable and **E**volvable **N**anomachines for **T**erraforming the **A**strobiology of **N**eptune - יצירה שהחזיקה במבנה המיקרוסקופי שלה את הפוטנציאל להפוך כוכב שלם. ";
"help.episodes.4" = "עם זאת, ההצלחה הייתה חמקמקה. הדור הראשון של PENTANים, שהיה כה מבטיח, יצא משליטה. הם שוחררו בעננות המתאן של Neptune, נוסעים על חלקיקי קרח בטבעות של Saturn. אך במקום להתחיל בתהליך הטרפורמציה, הם נעשו בלתי נשלטים, פראים.";
"help.episodes.5" = "כעת Tony*Theta7* מצא את עצמו בנקודת מפנה. האתגר שלו היה לעצב דור חדש של PENTANים, כאלה שלא יחזרו על כישלונות קודמיהם. העיצוב הקודם הצביע על נוכחות אפשרית של חיים ב-Neptune, דבר שהיה גם גילוי מרגש וגם מכשול במשימתם.";
"help.episodes.6" = "טוני ישב כפוף מעל עבודתו, גבותיו מכורכמות בריכוז. תמונות של עננות מתאן מסתחררות ושמיים כחולים מילאו את מסכיו. כל שורת קוד שכתב הייתה פתרון פוטנציאלי, רסן חדש על ה-PENTANים הפראים.";
"help.episodes.7" = "אצבעותיו עפו על המקלדת, והקליקים הקצביים של המקשים נעשו חלק מרעש הרקע של המעבדה. על המסך, תוכניות מורכבות של אוטומטים מולקולריים קמו לתחייה. כל עיצוב היה מתקדם יותר, יכול יותר, מבוקר יותר.";
"help.episodes.8" = "ה-PENTANים החדשים צריכים היו להיות שונים. הם צריכים היו להיות מעוצבים עם הידיעה ש-Neptune עשוי כבר לאכלס חיים, גורם שלא נלקח בחשבון בעיצוב הקודם. Tony*Theta7* היה צריך להבטיח שהננו-מכונות הללו יוכלו לפעול בהרמוניה עם צורות החיים הקיימות.";
"help.episodes.9" = "כשהזין את שורות הקוד האחרונות, הרגיש גל של ציפייה. בפקודה פשוטה, המדפסת קמה לתחייה ויצרה מודל תלת-ממדי של ה-PENTAN המשופר. המורכבות שלו הייתה מהפנטת - עדות לחדשנות האנושית ולרצון הבלתי מעורער לחקור את הלא נחקר.";
"help.episodes.10" = "עבור Tony*Theta7*, זו הייתה שיא של מאמצים בלתי נלאים, צעד קרוב יותר להשגת המטרה הנשגבת של טרפורמציה של Neptune. אך המבחן האמיתי של יצירתו עדיין היה מלפנים, במעמקים הקרים של אטמוספירת הכוכב הכחול, שם ה-PENTANים החדשים יאלפו את פראות קודמיהם או ייכנעו לאותו גורל.";
"help.episodes.11" = "הפרק של טרפורמציה של Neptune עדיין נכתב, ו-Tony*Theta7* אחז בעט.";

/// Help - The Game

"help.games.title" = "המשחקים";

"help.games.1" = "GoCAKs";
"help.games.1-1" = "GoCAKs /goʊ-kɜrks/ הוא\n***G***ame of ***C***ellular ***A***utomaton for ***K***id***s***";
"help.games.1-2" = "**האוטומט התאי** המוזכר כאן הוא משהו כמו תוכנית מחשב.";
"help.games.1-3" = "בגרסה זו של GoCAKs, אתה משחק על ידי שליטה בחלק שנקרא **PENTAN** (אוטומט תאי) בעולם המוצג על רשת דו-ממדית כמו לוח שחמט. ה-PENTAN נע בהתאם לתוכנית שניתנה מראש.";

"help.games.2" = "GoCAKs ככלי לימוד תכנות בסיסי";
"help.games.2-1" = "התוכנית של PENTAN נוצרת על ידי שילוב מספר הוראות.";
"help.games.2-2" = "על ידי שילוב הוראות, ניתן ליצור תנועות ותופעות מגוונות.";
"help.games.2-3" = "משחק ב-GoCAKs הוא כשלעצמו תכנות.";
"help.games.2-4" = "בזמן משחק GoCAKs, ניתן ללמוד באופן טבעי מושגי תכנות בסיסיים כגון לולאות, הסתעפות מותנית ומשתנים.";

"help.games.3" = "**PENTAN** כצורת חיים מתוכנתת";
"help.games.3-1" = "בעולם GoCAKs, האוטומט התאי נקרא **PENTAN**.";
"help.games.3-2" = "PENTAN, ננו-מכונה בעלת שכפול עצמי, מתנהג לפעמים כתא בודד ולפעמים כאורגניזם רב-תאי המשתף פעולה עם אחרים.";
"help.games.3-3" = "ל-PENTAN יש את התכונות הבאות.";

"help.games.pentan.title.1" = "האנרגיה";
"help.games.pentan.description.1" = "אנרגיה היא מקור הפעילות של PENTAN.\n\nככל שהאנרגיה יורדת, צבע ה-PENTAN נעשה חיוור יותר. כשהאנרגיה מגיעה לאפס, PENTAN נעלם.";
"help.games.pentan.title.2" = "המצב";
"help.games.pentan.description.2" = "ל-PENTAN יש מצב.\n\nהמצב הוא מספר המייצג את מיקום הקוד ש-PENTAN מבצע. כש-PENTAN מבצע קוד מסוים, המצב משתנה ומצביע על מיקום הקוד הבא לביצוע. PENTAN אינו יכול לדעת את מצבם של PENTANים אחרים.";
"help.games.pentan.title.3" = "הזיכרון";
"help.games.pentan.description.3" = "PENTAN יכול לזכור רק מספר אחד. חלק מהקודים משנים את התנהגותם בהתאם למספר ש-PENTAN זוכר.";
"help.games.pentan.title.4" = "הכיוון";
"help.games.pentan.description.4" = "ל-PENTAN יש כיוון. PENTAN יכול לשנות את כיוונו. קוד מסוים משפיע על ה-PENTAN השכן בכיוון שאליו PENTAN פונה.";
"help.games.pentan.title.5" = "כיוון היד";
"help.games.pentan.description.5" = "ל-PENTAN יש רק יד אחת.\n\nליד יש כיוון, ו-PENTAN יכול לשנות את כיוון היד. PENTAN יכול להשתמש ביד שלו כדי להיצמד ל-PENTAN השכן. כש-PENTAN שנמצא בקצה היד המושטת זז, הוא יכול גם לזוז איתו.";
"help.games.pentan.title.6" = "הצבע";
"help.games.pentan.description.6" = "ל-PENTAN יש צבע. \n\nאפשר לשנות את הצבע. PENTAN יכול לראות את הצבע של PENTANים אחרים.";
"help.games.pentan.title.7" = "הגנום";
"help.games.pentan.description.7" = "התוכנית של PENTAN נקראת גנום.\n\nגנום הוא אוסף של קודים המחוברים יחד בסדר.\n\nככל שהגנום ארוך יותר, כך הוא יכול לבטא תוכנית מורכבת יותר.\n\nעם זאת, ישנן הוראות שדורשות הרבה אנרגיה לביצוע, כמו הוראות לשכפול PENTAN, וככל שהגנום ארוך יותר.\n\nלכן, קח בחשבון שככל שהגנום קצר יותר, כך קל יותר ל-PENTAN להתרבות, וככל שהגנום ארוך יותר, כך קשה יותר להתרבות.";

"help.games.4" = "השדות";

"help.games.4-1" = "בעולם הרשת הדו-ממדית שבו PENTAN פועל, ישנם מקומות עם מאפיינים שונים.";

"help.games.fields.title.1" = "שדה אנרגיה";
"help.games.fields.description.1" = "זהו מקום שבו אנרגיה תרמית, המשמשת כאנרגיה ל-PENTAN, מפכה. PENTAN יכול לחדש את אנרגייתו כאן.";
"help.games.fields.title.2" = "שדה רעל";
"help.games.fields.description.2" = "זהו מקום שמכיל חומרים רבים רעילים ל-PENTAN. חומרים אלה ירוקנו את האנרגיה של PENTAN. אם PENTAN יישאר במקום זה זמן רב מדי, אנרגייתו תפחת בהדרגה והוא ייעלם בסופו של דבר.";
"help.games.fields.title.3" = "שדה קרינה";
"help.games.fields.description.3" = "זהו מקום שבו יש קרינה. עקב השפעות הקרינה, המבנה הננו העדין של PENTAN ניזוק, מה שגורם לשינויים במצב ובקוד של PENTAN.";
"help.games.fields.title.4" = "שדה קרינה";
"help.games.fields.description.4" = "זהו מקום שלתוכו PENTAN אינו יכול להיכנס.";
"help.games.fields.title.5" = "";
"help.games.fields.description.5" = "";

"help.games.timeandbudget" = "זמן ותקציב";
"help.games.timeandbudget.description" = "במצב ריצת מהירות, ישנן מגבלות על הזמן והתקציב שניתן להשתמש בהם בכל שלב.";

"help.games.time.title" = "זמן";
"help.games.time.description" = "במצב ריצת מהירות, יש הגבלת זמן לכל שלב. בזמן הנתון, עליך לחסל את כל האויבים. כשמגיעים למגבלת הזמן, המשחק נגמר ותצטרך להתחיל את השלב מההתחלה.";

"help.games.budget.title" = "תקציב";
"help.games.budget.description" = "במצב ריצת מהירות, יש הגבלת תקציב לכל שלב. מיקום, הסרה או שינוי של PENTANים צורך תקציב. ברגע שהתקציב נגמר, אינך יכול עוד להפעיל PENTANים בשלב זה. באיפוס, הזמן חוזר ל-0 והתקציב שנוצל גם מתאפס ל-0.";

"help.games.howtoplay" = "איך לשחק";
"help.games.speedrun.title" = "מצב ריצת מהירות";
"help.games.speedrun.description" = "זהו משחק שבו אתה מתחרה לחסל אויבים בזמן הקצר ביותר ובמשאבים המעטים ביותר.\n\nישנם שלבים משלב 1 עד שלב 7. בזמן ובתקציב הנתונים, נסה ליצור PENTANים ביעילות כדי לחסל את כל האויבים.";
"help.games.creative.title" = "מצב יצירתי";
"help.games.creative.description" = "זהו מצב שבו אתה יכול ליצור PENTANים בחופשיות ולערוך ניסויים שונים.\n\nשחרר את היצירתיות שלך וצור PENTANים שיוצרים תנועות ותופעות מעניינות.";

/// Help - FAQ

"help.faq.title" = "שאלות נפוצות";

"faqs.item1.title" = "שימוש בבתי ספר";
"faqs.item1.description" = "ש. האם ניתן להשתמש ב-GoCAKs בשיעורים בבית הספר?\n\nת. כן, ניתן להשתמש ב-GoCAKs בשיעורים בבית הספר. אתה חופשי ליצור ולהפיץ חומרים כגון צילומי מסך. גם מותר להשתמש בו בשיעורי תכנות המנוהלים למטרות רווח.";

"faqs.item2.title" = "יצירת סרטונים";
"faqs.item2.description" = "ש. האם אפשר ליצור ולשתף סרטונים של עצמי משחק GoCAKs?\n\nת. כן, אפשר ליצור סרטונים ולשתף אותם בפלטפורמות כמו YouTube. גם מותר להרוויח מסרטונים אלה.";

/// Codes

"help.codes.title" = "הקודים";
"help.codes.code.title" = "קוד";
"help.codes.code.description" = "קוד אחד מורכב מפקודה ופרמטר.\n\nהפרמטר מיוצג על ידי מספר, וחלק מהפקודות משתמשות בפרמטר ואחרות לא.\n\nההוראות ב-GoCAKs נבחרו בקפידה ומעוצבות היטב.\n\nלמרות שכל הוראה פשוטה וקלה להבנה, האפשרויות בתנועות ובתופעות שניתן ליצור מהשילובים שלהן אינסופיות.\n\nהמחזה של PENTANים מעוצבים בקפידה המתחרים על הישרדות ככל הנראה ייצור תופעה דומה למערכת אקולוגית.";

